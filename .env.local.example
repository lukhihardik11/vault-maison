# ═══════════════════════════════════════════════════════════════
# VAULT MAISON — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# All NEXT_PUBLIC_ vars are exposed to the browser.
# ═══════════════════════════════════════════════════════════════

# ─── DEPLOYMENT MODE ──────────────────────────────────────────
# Leave NEXT_PUBLIC_CONCEPT_ID empty for SHOWCASE mode (all 10 themes)
# Set to a concept ID for SINGLE-THEME mode (one customer's site)
# Options: minimal | vault | gallery | salon | atelier | archive |
#          observatory | theater | marketplace | maison
NEXT_PUBLIC_CONCEPT_ID=

# ─── BUSINESS INFO (for single-theme deployments) ────────────
NEXT_PUBLIC_BUSINESS_NAME=Vault Maison
NEXT_PUBLIC_TAGLINE=Luxury Jewelry, Reimagined
NEXT_PUBLIC_DESCRIPTION=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_ADDRESS=

# ─── BRANDING ────────────────────────────────────────────────
NEXT_PUBLIC_LOGO_URL=
NEXT_PUBLIC_FAVICON_URL=

# ─── SOCIAL LINKS ────────────────────────────────────────────
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_PINTEREST=
NEXT_PUBLIC_SOCIAL_TIKTOK=

# ─── FEATURE FLAGS ───────────────────────────────────────────
# Set to 'true' to enable, 'false' to disable
# Most features are ON by default; only GemHub, chat, and
# analytics require explicit opt-in.
NEXT_PUBLIC_FEATURE_GEMHUB=false
NEXT_PUBLIC_FEATURE_REVIEWS=true
NEXT_PUBLIC_FEATURE_WISHLIST=true
NEXT_PUBLIC_FEATURE_BESPOKE=true
NEXT_PUBLIC_FEATURE_CHAT=false
NEXT_PUBLIC_FEATURE_SEARCH=true
NEXT_PUBLIC_FEATURE_RECENTLY_VIEWED=true
NEXT_PUBLIC_FEATURE_ANALYTICS=false

# ─── SUPABASE (Database + Auth) ──────────────────────────────
# Leave empty for demo mode (local data, no auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── STRIPE (Payments) ──────────────────────────────────────
# Leave empty for demo checkout mode
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── GEMHUB 360° VIEWER ─────────────────────────────────────
# GemHub catalog URL and share base for 360° product views
NEXT_PUBLIC_GEMHUB_CATALOG_URL=
GEMHUB_API_URL=https://hub.gemlightbox.com
GEMHUB_SHARE_BASE=https://hub.gemlightbox.com/share

# ─── SEO ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://vaultmaison.com
NEXT_PUBLIC_OG_IMAGE=
NEXT_PUBLIC_APP_URL=http://localhost:3000
